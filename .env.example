# ============================================
# AGROBOT AI - ENVIRONMENT VARIABLES
# ============================================
# ⚠️  NEVER put real keys here — this file is committed to git
# Copy this to .env.local (git-ignored) and fill in real values
# All real keys must ONLY go into Vercel Environment Variables

# === SUPABASE ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# === GEMINI AI ===
# Get from: https://aistudio.google.com/app/apikey
# ⚠️  Restrict key to "Generative Language API" in Google Cloud Console
GEMINI_API_KEY=your_gemini_api_key_here

# === FACEBOOK MESSENGER ===
META_VERIFY_TOKEN=your_random_verify_token_here
META_PAGE_ACCESS_TOKEN=your_page_access_token_here
META_APP_SECRET=your_app_secret_here

# === RATE LIMITS ===
RATE_LIMIT_HOURLY=10
RATE_LIMIT_DAILY=100
DAILY_TOTAL_LIMIT=500

# === APP URL ===
NEXT_PUBLIC_APP_URL=https://agro-ai-bd.vercel.app
